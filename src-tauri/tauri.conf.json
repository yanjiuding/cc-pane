{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-panes",
  "version": "0.10.4",
  "identifier": "com.ccpanes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14200",
    "beforeBuildCommand": "npm run build && node scripts/build-hook.cjs && node scripts/copy-hook.cjs",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "CC-Panes",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "maximized": true,
        "decorations": false
      },
      {
        "label": "ccchan",
        "title": "cc酱",
        "url": "index.html?mode=ccchan",
        "visible": false,
        "width": 120,
        "height": 120,
        "x": -9999,
        "y": -9999,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/cc-panes-cli-hook*",
      "binaries/cc-panes-daemon*",
      "binaries/cc-panes-web*",
      "resources/web-dist/**/*",
      "resources/claude-bundle/.claude/commands/ccbook/*",
      "resources/claude-bundle/.claude/agents/*",
      "resources/ccchan/**/*",
      "resources/claude-bundle/CLAUDE.md",
      "resources/claude-bundle/default-skills/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEQzBGQzI0NkMyM0ExMzgKUldRNG9TTnNKUHpBdmV3WDM4QUZHOGNZc0VLaFRYVEVZaEZ1ckFSMlh1VVlDQXZtVms3VU5ISGEK",
      "endpoints": [
        "https://github.com/wuxiran/cc-pane/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }

}
